# This is Git's per-user configuration file.
[user]
	name = Lili Szabó
	email = lilasaba@gmail.com
[core]
	editor = vim
[alias]
	hist = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
